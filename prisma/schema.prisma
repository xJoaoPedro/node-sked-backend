generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int               @id @default(autoincrement())
  name                 String            @db.VarChar(255)
  email                String            @unique @db.VarChar(255)
  password             String            @db.VarChar(255)
  phone                String            @db.VarChar(11)
  status               status_enum       @default(ACTIVE)
  last_login           DateTime?         @db.Timestamptz(6)
  created_at           DateTime          @default(now()) @db.Timestamptz(6)
  updated_at           DateTime          @updatedAt @db.Timestamptz(6)

  // relações
  employee             Employee?

  @@map("users")
}

model Company {
  id               Int                 @id @default(autoincrement())
  legal_name       String              @db.VarChar(255)
  fantasy_name     String              @db.VarChar(255)
  cnpj             String              @db.VarChar(14)
  email            String              @unique @db.VarChar(255)
  password         String              @db.VarChar(255)
  phone            String?             @db.VarChar(11)
  interval_slot    Int                 @default(15)
  plan             plan_enum           @default(FREE)
  status           company_status_enum @default(PENDING)
  approve_date     DateTime?           @db.Timestamptz(6)
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at       DateTime            @updatedAt @db.Timestamptz(6)

  // relações
  employees        Employee[]
  addresses        Address[]
  appointments     Appointment[]
  botInteractions  BotInteraction[]
  scheduleBlocks   ScheduleBlock[]
  scheduleOpenings ScheduleOpening[]
  services         Service[]
  signatures       Signature[]
  products         Product[]
  customers        CompanyCustomer[]

  @@map("companies")  
}

model Customer {
  id                 Int               @id @default(autoincrement())
  name               String            @db.VarChar(255)
  phone              String            @unique @db.VarChar(11)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @updatedAt @db.Timestamptz(6)

  companies          CompanyCustomer[]
  appointmentClients Appointment[]     @relation("client")
  botInteractions    BotInteraction[]

  @@map("customers")
}

model CompanyCustomer {
  id          Int      @id @default(autoincrement())
  company_id  Int
  customer_id Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([company_id, customer_id])
  @@index([company_id])
  @@index([customer_id])
  @@map("company_customers")
}

model Employee {
  id         Int      @id @default(autoincrement())
  company_id Int
  user_id    Int?     @unique

  name       String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  phone      String   @db.VarChar(11)

  role       role_enum
  status     status_enum @default(ACTIVE)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // relações
  services           EmployeeService[]
  scheduleOpenings   ScheduleOpening[]
  scheduleBlocks     ScheduleBlock[]
  appointments       Appointment[]

  @@index([company_id])
  @@map("employees")
}

model EmployeeService {
  employee_id Int
  service_id  Int

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@id([employee_id, service_id])
  @@map("employee_services")
}

model Address {
  id           Int      @id @default(autoincrement())
  company_id   Int
  cep          String   @db.VarChar(10)
  street       String   @db.VarChar(255)
  number       String   @db.VarChar(20)
  complement   String?  @db.VarChar(255)
  neighborhood String   @db.VarChar(255)
  city         String   @db.VarChar(255)
  state        String   @db.VarChar(2)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @updatedAt @db.Timestamptz(6)

  company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("addresses")
}

model ScheduleOpening {
  id          Int      @id @default(autoincrement())
  company_id  Int
  employee_id Int
  week_day    Int
  start_time  DateTime @db.Time(6)
  end_time    DateTime @db.Time(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee    Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("schedule_openings")
}

model ScheduleBlock {
  id          Int       @id @default(autoincrement())
  company_id  Int
  employee_id Int
  start_time  DateTime  @db.Timestamptz(6)
  end_time    DateTime? @db.Timestamptz(6)
  reason      String    @db.VarChar(255)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @updatedAt @db.Timestamptz(6)

  company     Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("schedule_blocks")
}

model Service {
  id               Int           @id @default(autoincrement())
  company_id       Int
  name             String        @db.VarChar(255)
  category         category_enum @default(OTHER)
  description      String?       @db.VarChar(255)
  duration_minutes Int
  price            Decimal       @db.Decimal(10, 2)
  commission       Decimal       @db.Decimal(5, 2)
  status           status_enum   @default(ACTIVE)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @updatedAt @db.Timestamptz(6)

  company      Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  appointments Appointment[]
  employees    EmployeeService[]

  @@map("services")
}

model Appointment {
  id             Int                @id @default(autoincrement())
  company_id     Int
  service_id     Int
  employee_id    Int
  client_id      Int
  start_time     DateTime           @db.Timestamptz(6)
  end_time       DateTime           @db.Timestamptz(6)
  observations   String?            @db.VarChar(255)
  status         appointment_status @default(PENDING)
  cancel_reason  cancel_reason?
  payment_method payment_method_enum?

  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  updated_at     DateTime           @updatedAt @db.Timestamptz(6)

  client   Customer @relation("client", fields: [client_id], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([company_id, start_time])
  @@index([employee_id, start_time])
  @@map("appointments")
}

model BotInteraction {
  id         Int                         @id @default(autoincrement())
  company_id Int
  client_id  Int
  type       bot_interaction_type_enum
  status     bot_interaction_status_enum
  data       Json
  created_at DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at DateTime                    @updatedAt @db.Timestamptz(6)

  client     Customer @relation(fields: [client_id], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([client_id])
  @@map("bot_interactions")
}

model Signature {
  id                Int                   @id @default(autoincrement())
  company_id        Int
  plan              plan_enum             @default(FREE)
  status            signature_status_enum @default(PENDING)
  start_date        DateTime              @db.Timestamptz(6)
  renovation_date   DateTime              @db.Timestamptz(6)
  cancellation_date DateTime?             @db.Timestamptz(6)
  paid              Boolean               @default(false)
  created_at        DateTime              @default(now()) @db.Timestamptz(6)
  updated_at        DateTime              @updatedAt @db.Timestamptz(6)

  company           Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("signatures")
}

model Product {
  id           Int           @id @default(autoincrement())
  company_id   Int
  name         String        @db.VarChar(255)
  category     category_enum @default(OTHER)
  quantity     Int           @default(0)
  cost_price   Decimal       @db.Decimal(10, 2)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @updatedAt @db.Timestamptz(6)

  company      Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@map("products")
}

enum status_enum {
  ACTIVE
  DISABLED
}

enum plan_enum {
  FREE
  PRO
}

enum company_status_enum {
  PENDING
  APPROVED
  DENIED
}

enum role_enum {
  MANAGER
  EMPLOYEE
}

enum appointment_status {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum cancel_reason {
  NO_SHOW
  SCHEDULE_CONFLICT
  ILLNESS
  EMERGENCY
  PROFESSIONAL_UNAVAILABLE
  OTHER
}

enum bot_interaction_type_enum {
  APPOINTMENT
  CANCELLATION
  REAPPOINTMENT
  INQUIRY
  OTHER
}

enum bot_interaction_status_enum {
  IN_PROGRESS
  WAITING_PAYMENT
  SCHEDULED
  CANCELED
  OTHER
}

enum signature_status_enum {
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
}

enum payment_method_enum {
  PIX
  CREDIT
  DEBIT
  CASH
}

enum category_enum {
  HAIR
  BEARD
  AESTHETIC
  NAILS
  MASSAGE
  THERAPY
  HEALTH
  DENTAL
  FITNESS
  BEAUTY
  AUTOMOTIVE
  TECHNICAL
  HOME_SERVICE
  PET
  CONSULTING
  EDUCATION
  OTHER
}
