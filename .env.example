# FRONTEND
# -----------------
CORS_URL= # URL do Frontend que irá consumir a API, necessário para liberação de CORS

# BACKEND
# -----------------
API_PORT= # porta que será usada para hospedar a API, default 3000

# DATABASE CONNECTION
# -----------------
DB_HOST=     # onde está o banco (cloud, local, endereço web, etc.)
DB_PORT=     # porta de acesso ao Postgres
DB_DATABASE= # nome do banco
DB_USERNAME= # usuário
DB_PASSWORD= # senha

# PRISMA
# -----------------
DATABASE_URL= # "postgresql://usuario:senha@host:porta/nomeDoBanco"

# JWT
# -----------------
JWT_SECRET= # chave que será usada para aleatorizar os tokens, ideal que seja longo e aleatório

# ANTHROPIC
# -----------------
ANTHROPIC_API_KEY= # sua chave da API da Anthropic
ANTHROPIC_MODEL= # modelo padrão sugerido
ANTHROPIC_BASE_URL= # base URL padrão da API

# EVOLUTION API
# -----------------
EVOLUTION_API_URL= # URL base da Evolution API
EVOLUTION_API_KEY= # mesma chave configurada em evolution-api/.env como AUTHENTICATION_API_KEY
EVOLUTION_WEBHOOK_URL= # endpoint deste backend para receber eventos
EVOLUTION_WEBHOOK_SECRET= # segredo opcional enviado no header x-webhook-secret
EVOLUTION_AUTO_REPLY_ENABLED=true # desative com false para nao responder automaticamente
EVOLUTION_AUTO_REPLY_MAX_MESSAGE_AGE_SECONDS=180 # ignora mensagens antigas; backlog de reconexao tambem e descartado a partir do ultimo connection.update
APP_TIMEZONE= # Timezone Padrão do app
